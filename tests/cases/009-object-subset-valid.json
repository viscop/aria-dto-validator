  "name": "object subset allows extra backend keys",
  "userDTO": {
    "networks": [
      {
        "name": "prod-net",
        "zone": "eu"
      }
    ]
  },
  "backendDTO": {
    "allowedNetworks": [
      {
        "name": "prod-net",
        "zone": "eu",
        "id": "net-123"
      }
